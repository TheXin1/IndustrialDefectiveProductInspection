<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.industrialdefectiveproductinspection.mapper.PermissionMapper">
    <resultMap id="PermissionResult" type="com.example.industrialdefectiveproductinspection.domain.Permission">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="type" property="type" />
        <result column="parent_id" property="parentId" />
        <result column="path" property="path" />
        <result column="method" property="method" />
        <result column="description" property="description" />
        <result column="sort_order" property="sortOrder" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <select id="selectAll" resultMap="PermissionResult">
        SELECT id, code, name, type, parent_id, path, method, description, sort_order, created_at, updated_at
        FROM sys_permission
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectByIds" resultMap="PermissionResult">
        SELECT id, code, name, type, parent_id, path, method, description, sort_order, created_at, updated_at
        FROM sys_permission
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <insert id="insert" parameterType="com.example.industrialdefectiveproductinspection.domain.Permission" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_permission (code, name, type, parent_id, path, method, description, sort_order)
        VALUES (#{code}, #{name}, #{type}, #{parentId}, #{path}, #{method}, #{description}, #{sortOrder})
    </insert>

    <delete id="deleteById">
        DELETE FROM sys_permission WHERE id = #{id}
    </delete>
</mapper>

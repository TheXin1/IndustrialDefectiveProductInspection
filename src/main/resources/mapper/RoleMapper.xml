<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.industrialdefectiveproductinspection.mapper.RoleMapper">
    <resultMap id="RoleResult" type="com.example.industrialdefectiveproductinspection.domain.Role">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="description" property="description" />
        <result column="built_in" property="builtIn" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <select id="selectAll" resultMap="RoleResult">
        SELECT id, code, name, description, built_in, created_at, updated_at
        FROM sys_role
        ORDER BY id ASC
    </select>

    <select id="selectById" resultMap="RoleResult">
        SELECT id, code, name, description, built_in, created_at, updated_at
        FROM sys_role
        WHERE id = #{id}
    </select>

    <select id="selectByCode" resultMap="RoleResult">
        SELECT id, code, name, description, built_in, created_at, updated_at
        FROM sys_role
        WHERE code = #{code}
        LIMIT 1
    </select>

    <insert id="insert" parameterType="com.example.industrialdefectiveproductinspection.domain.Role" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_role (code, name, description, built_in)
        VALUES (#{code}, #{name}, #{description}, #{builtIn})
    </insert>

    <update id="update" parameterType="com.example.industrialdefectiveproductinspection.domain.Role">
        UPDATE sys_role
        <set>
            <if test="code != null">code = #{code},</if>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="builtIn != null">built_in = #{builtIn},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_role WHERE id = #{id}
    </delete>
</mapper>
